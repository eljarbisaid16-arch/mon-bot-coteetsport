# Token Bearer obligatoire pour protéger l'API du bot.
# À configurer aussi côté app PariMatchia (page Bot Setup).
API_TOKEN=changez-moi-par-une-longue-cle-aleatoire

# Clé API 2captcha pour la résolution des reCAPTCHA.
CAPTCHA_API_KEY=votre-cle-2captcha

# URL cible (par défaut coteetsport.ma)
TARGET_URL=https://www.coteetsport.ma/

# (Auto sur Railway) Port HTTP
PORT=8000
