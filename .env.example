# Token Bearer obligatoire pour protéger l'API du bot.
API_TOKEN=changez-moi-par-une-longue-cle-aleatoire

# Clé API 2captcha (optionnel, pour résoudre reCAPTCHA)
CAPTCHA_API_KEY=

# URL cible
TARGET_URL=https://www.coteetsport.ma/cote-sport

# === PROXY RÉSIDENTIEL MAROCAIN (FORTEMENT RECOMMANDÉ) ===
# Sans proxy MA, Akamai bloque les IPs datacenter de Railway.
# Fournisseurs : Bright Data, Smartproxy, Oxylabs, IPRoyal (zone country=ma)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
PROXY_SCHEME=http

# (Auto sur Railway) Port HTTP
PORT=8000
